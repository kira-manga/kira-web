# Production builds require the Play app-signing certificate SHA-256 fingerprint.
KIRA_WEB_PRODUCTION=false
ANDROID_APP_SHA256_CERT_FINGERPRINT=AA:BB:...:FF

# Defaults shown here match the shipping app configuration.
ANDROID_PACKAGE_NAME=me.manga.kira
APPLE_TEAM_ID=7CGZ2343AA
IOS_BUNDLE_ID=me.manga.kira
# Internal backend origin used only by the standalone Next.js server.
KIRA_TUTORIAL_API_URL=http://localhost:8080
# Browser-visible API origin used for immutable tutorial media URLs and CSP.
NEXT_PUBLIC_KIRA_API_URL=http://localhost:8080
